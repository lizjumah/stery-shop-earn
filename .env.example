# ─────────────────────────────────────────────────────────────
# Stery Shop & Earn — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real secrets.
# In production, set these in the Vercel dashboard under
# Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Backend API (Express on Render)
# Production:  https://stery-backend.onrender.com
# Development: http://localhost:3000
VITE_BACKEND_URL=http://localhost:3000

# Supabase — get these from https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-supabase-anon-key>
